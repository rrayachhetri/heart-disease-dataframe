# CardioSense — environment variables (TEMPLATE ONLY)
# Do NOT commit a real .env with secrets to the repository.
# Copy this file to a local, untracked .env and fill in your values.

# ── Server ──────────────────────────────────────────────────────────────────
# A long, random string used for JWT signing — required, no default in production
# SECRET_KEY=your-long-random-secret-key-here
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed for local dev):
# DATABASE_URL=sqlite:///./cardiosense.db
# PostgreSQL (example for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/cardiosense

# ── Schema management ────────────────────────────────────────────────────────
# Set to "true" only for local dev (SQLite). Use Alembic migrations in production.
# AUTO_CREATE_TABLES=true

# ── ML Model ────────────────────────────────────────────────────────────────
# MODEL_PATH=models/rf_model.joblib  # override if needed
