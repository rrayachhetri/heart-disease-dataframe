pipeline {
    agent any

    options {
        // CloudBees CI: discard old builds to save disk space
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '5'))
        timeout(time: 30, unit: 'MINUTES')
        skipStagesAfterUnstable()
    }

    environment {
        DOCKER_IMAGE      = "heart-disease-api"
        SONAR_PROJECT_KEY = "heart-disease"
        // SONAR_TOKEN bound via withCredentials below; do not echo credentials here
    }

    stages {

        // ─────────────────────────────────────────────
        // 1. SECRETS SCAN  –  TruffleHog v3
        //    Scans git history + current diff for leaked
        //    API keys, passwords, tokens, etc.
        // ─────────────────────────────────────────────
        stage('Secrets Scan (TruffleHog)') {
            steps {
                script {
                    // Run TruffleHog in its official Docker image so no
                    // local install is required on the Jenkins agent.
                    // --fail exits non-zero when secrets are found.
                    def truffleResult = sh(
                        returnStatus: true,
                        script: """
                            docker run --rm \
                                -v "\${WORKSPACE}:/repo" \
                                trufflesecurity/trufflehog:latest \
                                    git \
                                    --repo=/repo \
                                    --since-commit HEAD~1 \
                                    --only-verified \
                                    --fail \
                                    --json \
                            | tee trufflehog-results.json
                        """
                    )
                    // Archive report regardless of outcome
                    archiveArtifacts artifacts: 'trufflehog-results.json', allowEmptyArchive: true

                    if (truffleResult != 0) {
                        error("TruffleHog detected verified secrets in this PR. Review trufflehog-results.json and rotate any exposed credentials before merging.")
                    }
                }
            }
        }

        // ─────────────────────────────────────────────
        // 2. UNIT TESTS + COVERAGE
        //    pytest produces JUnit XML and coverage.xml
        //    which SonarQube ingests in the next stage.
        // ─────────────────────────────────────────────
        stage('Unit Tests') {
            steps {
                sh """
                    python -m pip install --quiet -r requirements.txt
                    python -m pytest src/ \
                        --junitxml=test-results.xml \
                        --cov=src \
                        --cov-report=xml:coverage.xml \
                        --cov-report=term-missing \
                        -v || true
                """
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'test-results.xml'
                }
            }
        }

        // ─────────────────────────────────────────────
        // 3. SONARQUBE ANALYSIS
        //    Requires the SonarQube Scanner and the
        //    CloudBees / Jenkins SonarQube plugin.
        //    Quality Gate result gates the PR merge.
        // ─────────────────────────────────────────────
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') { // 'SonarQube' = server name in Manage Jenkins → Configure System
                    sh """
                        sonar-scanner \
                            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                            -Dsonar.pullrequest.key=${env.CHANGE_ID ?: ''} \
                            -Dsonar.pullrequest.branch=${env.CHANGE_BRANCH ?: env.BRANCH_NAME} \
                            -Dsonar.pullrequest.base=${env.CHANGE_TARGET ?: 'main'} \
                            -Dsonar.python.coverage.reportPaths=coverage.xml \
                            -Dsonar.python.xunit.reportPath=test-results.xml
                    """
                }
            }
        }

        // Quality Gate blocks merge if thresholds are breached
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // ─────────────────────────────────────────────
        // 4. DOCKER BUILD VERIFICATION
        //    Ensures the image builds cleanly; does NOT
        //    push to a registry on PR builds.
        // ─────────────────────────────────────────────
        stage('Docker Build Verify') {
            steps {
                sh """
                    docker build \
                        --no-cache \
                        --tag ${DOCKER_IMAGE}:pr-${env.CHANGE_ID ?: env.BUILD_NUMBER} \
                        .
                """
            }
            post {
                always {
                    // Clean up dangling image to reclaim disk space
                    sh "docker rmi ${DOCKER_IMAGE}:pr-${env.CHANGE_ID ?: env.BUILD_NUMBER} || true"
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'test-results.xml,coverage.xml', allowEmptyArchive: true
            cleanWs()
        }
        failure {
            echo "PR scan failed. Check TruffleHog secrets report, SonarQube Quality Gate, or Docker build logs above."
        }
        success {
            echo "All PR scans passed: no secrets detected, quality gate met, and Docker image builds successfully."
        }
    }
}
