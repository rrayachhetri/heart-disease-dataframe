# CardioSense — environment variables
# Copy this to .env and fill in your values

# ── Server ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed for local dev):
DATABASE_URL=sqlite:///./cardiosense.db
# PostgreSQL (uncomment for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/cardiosense

# ── ML Model ─────────────────────────────────────────────────────────────────
# MODEL_PATH=models/rf_model.joblib  # override if needed
